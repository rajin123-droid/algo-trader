# ─────────────────────────────────────────────────────────────────────────────
# API Server — Environment Variables
#
# Copy this file to .env and fill in the values for local development.
# Production values should be set via deployment secrets, never committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080

# ── Database ─────────────────────────────────────────────────────────────────
# Required. PostgreSQL connection string.
DATABASE_URL=postgres://user:password@localhost:5432/algo_terminal

# ── Auth / Encryption ────────────────────────────────────────────────────────
# Required. Used for JWT signing AND AES-256-GCM API key encryption.
# Must be at least 10 characters. Use a long random string in production.
SESSION_SECRET=change_me_to_a_long_random_secret_in_production

# ── Redis (optional) ─────────────────────────────────────────────────────────
# If not set, in-memory fallback is used for order queue and pub/sub.
# REDIS_URL=redis://localhost:6379

# ── Binance Exchange (optional) ──────────────────────────────────────────────
# Without these, the system runs in paper-trading mode only.
# BINANCE_API_KEY=your_binance_api_key
# BINANCE_SECRET_KEY=your_binance_secret_key
# BINANCE_BASE_URL=https://testnet.binance.vision

# ── Risk Limits ──────────────────────────────────────────────────────────────
# Maximum single-order notional value in USD. Hard cap enforced by order router.
# MAX_ORDER_NOTIONAL_USD=10000
